{
  "name": "supervizio-website",
  "version": "1.0.0",
  "private": true,
  "description": "Supervizio commercial website",
  "scripts": {
    "build": "node build.js",
    "watch": "node watch.js",
    "dev": "npm run build && npx browser-sync start --server site --files 'site/**/*.html,site/css/**,site/js/**' --no-notify --port 3000",
    "serve": "npx browser-sync start --server site --files 'site/**/*' --no-notify --port 3000"
  },
  "devDependencies": {
    "chokidar": "^3.6.0",
    "nunjucks": "^3.2.4"
  }
}
