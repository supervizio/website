{% set title = "Superviz.io — Real-Time Infrastructure Monitoring" %}
{% set description = "Monitor your entire infrastructure in real time. Get instant alerts, deep visibility, and actionable insights. Trusted by IT teams worldwide." %}
{% set ogTitle = "Superviz.io — Real-Time Infrastructure Monitoring" %}
{% set ogDescription = "Monitor your entire infrastructure in real time. Instant alerts, deep visibility, actionable insights." %}
{% set ogType = "website" %}
{% set ogUrl = "https://superviz.io" %}
{% set twitterCard = "summary_large_image" %}
{% set canonical = "https://superviz.io" %}
{% extends "layouts/base.njk" %}

{% block content %}
    <section class="hero">
      <div class="container">
        <span class="badge">Now in General Availability</span>
        <h1 style="margin-top: 1.5rem">
          Monitor your infrastructure.<br /><span class="text-gradient"
            >Fix issues before they happen.</span
          >
        </h1>
        <p class="subtitle subtitle-wide">
          Superviz.io gives your team real-time visibility into servers,
          containers, networks, and applications. Detect anomalies in seconds,
          not hours.
        </p>
        <div class="hero-cta">
          <a href="pricing.html" class="btn btn-primary btn-lg"
            >Start Free Trial &rarr;</a
          >
          <a href="features.html" class="btn btn-secondary btn-lg"
            >See Features</a
          >
        </div>
        <div class="hero-metrics">
          <div class="metric">
            <div class="metric-value">99.9%</div>
            <div class="metric-label">Uptime SLA</div>
          </div>
          <div class="metric">
            <div class="metric-value">&lt;30s</div>
            <div class="metric-label">Alert Latency</div>
          </div>
          <div class="metric">
            <div class="metric-value">500+</div>
            <div class="metric-label">Integrations</div>
          </div>
          <div class="metric">
            <div class="metric-value">10K+</div>
            <div class="metric-label">Servers Monitored</div>
          </div>
        </div>
      </div>
    </section>

    <section class="logos-section">
      <div class="container text-center">
        <p
          style="
            color: var(--text-muted);
            font-size: var(--text-sm);
            margin-bottom: var(--space-8);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            font-weight: 600;
          "
        >
          Trusted by leading engineering teams
        </p>
        <div class="logos-grid">
          <span>Airbus</span><span>Thales</span><span>OVHcloud</span
          ><span>Scaleway</span> <span>BlaBlaCar</span><span>Doctolib</span
          ><span>Datadog</span><span>Qonto</span>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center" style="margin-bottom: var(--space-12)">
          <span class="badge">Core Capabilities</span>
          <h2 style="margin-top: var(--space-4)">
            Everything you need to<br /><span class="text-gradient"
              >keep systems running</span
            >
          </h2>
          <p class="subtitle subtitle-wide" style="margin-top: var(--space-4)">
            From real-time dashboards to intelligent alerting, Superviz.io covers
            your entire monitoring stack.
          </p>
        </div>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">&#9889;</div>
            <h3>Real-Time Monitoring</h3>
            <p>
              Sub-second metric collection across servers, containers, and cloud
              instances. See what's happening right now, not five minutes ago.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128276;</div>
            <h3>Intelligent Alerts</h3>
            <p>
              ML-powered anomaly detection reduces alert noise by 90%. Get
              notified about real issues, not false positives.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128200;</div>
            <h3>Custom Dashboards</h3>
            <p>
              Build dashboards that tell a story. Drag-and-drop widgets,
              real-time charts, and shareable views for every team.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128268;</div>
            <h3>500+ Integrations</h3>
            <p>
              Connect to AWS, GCP, Azure, Kubernetes, Docker, Prometheus, and
              hundreds more. One agent, full visibility.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128202;</div>
            <h3>Automated Reports</h3>
            <p>
              Weekly and monthly reports generated automatically. Uptime stats,
              incident summaries, capacity forecasts.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128272;</div>
            <h3>API &amp; Extensibility</h3>
            <p>
              Full REST API for custom integrations. Webhooks, Terraform
              provider, and CLI tools for your pipeline.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--bg-secondary)">
      <div class="container">
        <div class="text-center" style="margin-bottom: var(--space-12)">
          <span class="badge">Enterprise Security</span>
          <h2 style="margin-top: var(--space-4)">
            Built for teams that<br /><span class="text-gradient"
              >take security seriously</span
            >
          </h2>
        </div>
        <div class="security-grid">
          <div class="security-card">
            <div class="security-icon">&#128737;</div>
            <h3>SOC 2 Type II</h3>
            <p>
              Annual independent audits verify our security controls. Your data
              is protected by industry-leading standards.
            </p>
          </div>
          <div class="security-card">
            <div class="security-icon">&#128274;</div>
            <h3>End-to-End Encryption</h3>
            <p>
              TLS 1.3 in transit, AES-256 at rest. Zero plaintext storage of
              sensitive metrics.
            </p>
          </div>
          <div class="security-card">
            <div class="security-icon">&#127919;</div>
            <h3>GDPR &amp; HIPAA Ready</h3>
            <p>
              Data residency options in EU and US. Full GDPR compliance with DPA
              available.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center" style="margin-bottom: var(--space-12)">
          <span class="badge">Customer Stories</span>
          <h2 style="margin-top: var(--space-4)">
            Teams ship faster with <span class="text-gradient">Superviz.io</span>
          </h2>
        </div>
        <div class="testimonials-grid">
          <div class="testimonial-card">
            <div class="testimonial-quote">
              Superviz.io cut our incident response time by 60%. The anomaly
              detection catches issues our old monitoring completely missed.
            </div>
            <div class="testimonial-author">
              <div class="testimonial-avatar">ML</div>
              <div>
                <div class="testimonial-name">Marc Laurent</div>
                <div class="testimonial-role">VP Engineering, CloudScale</div>
              </div>
            </div>
          </div>
          <div class="testimonial-card">
            <div class="testimonial-quote">
              We replaced three monitoring tools with Superviz.io. One dashboard,
              one agent, complete visibility. The ROI was immediate.
            </div>
            <div class="testimonial-author">
              <div class="testimonial-avatar">SD</div>
              <div>
                <div class="testimonial-name">Sarah Dubois</div>
                <div class="testimonial-role">SRE Lead, FinSecure</div>
              </div>
            </div>
          </div>
          <div class="testimonial-card">
            <div class="testimonial-quote">
              The Kubernetes monitoring alone is worth it. Auto-discovers pods,
              tracks resource usage, alerts on OOM kills before they cascade.
            </div>
            <div class="testimonial-author">
              <div class="testimonial-avatar">TN</div>
              <div>
                <div class="testimonial-name">Thomas Nguyen</div>
                <div class="testimonial-role">Platform Architect, DataFlow</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <h2>
          Ready to see everything<br /><span class="text-gradient"
            >in real time?</span
          >
        </h2>
        <p class="subtitle subtitle-wide">
          Start monitoring in minutes. No credit card required. Free for up to 5
          hosts.
        </p>
        <div class="hero-cta" style="margin-top: var(--space-8)">
          <a href="pricing.html" class="btn btn-primary btn-lg"
            >Start Free Trial &rarr;</a
          >
          <a href="contact.html" class="btn btn-secondary btn-lg"
            >Talk to Sales</a
          >
        </div>
      </div>
    </section>
{% endblock %}
