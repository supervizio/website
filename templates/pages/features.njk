{% set title = "Features — Superviz.io" %}
{% set description = "Explore Superviz.io's monitoring features: real-time metrics, intelligent alerts, custom dashboards, 500+ integrations, and more." %}
{% set canonical = "https://superviz.io/features" %}
{% extends "layouts/base.njk" %}

{% block content %}
    <section class="page-header">
      <div class="container">
        <span class="badge">Platform</span>
        <h1 style="margin-top: var(--space-4)">
          Powerful monitoring,<br /><span class="text-gradient"
            >zero complexity</span
          >
        </h1>
        <p class="subtitle subtitle-wide" style="margin-top: var(--space-4)">
          One platform to monitor everything. From bare-metal servers to
          serverless functions, Superviz.io adapts to your stack.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">&#9889;</div>
            <h3>Real-Time Metrics</h3>
            <p>
              Collect metrics every second from thousands of hosts. CPU, memory,
              disk, network, and custom metrics — all in one place with zero
              sampling.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128276;</div>
            <h3>Intelligent Alerting</h3>
            <p>
              ML-powered anomaly detection learns your baseline and alerts on
              deviations. Composite alerts, escalation policies, and on-call
              schedules built in.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128200;</div>
            <h3>Custom Dashboards</h3>
            <p>
              Drag-and-drop dashboard builder with 30+ widget types. Line
              charts, heatmaps, topologies, log streams. Share with a link or
              embed anywhere.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128268;</div>
            <h3>500+ Integrations</h3>
            <p>
              Native integrations for AWS, GCP, Azure, Kubernetes, Docker,
              Prometheus, Grafana, Datadog, PagerDuty, Slack, and hundreds more.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128269;</div>
            <h3>Log Management</h3>
            <p>
              Centralized logging with full-text search, structured parsing, and
              correlation with metrics. Tail logs in real time or query
              petabytes in seconds.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#127760;</div>
            <h3>Network Monitoring</h3>
            <p>
              Layer 3-7 visibility with flow analysis, packet inspection, and
              DNS monitoring. Map your entire network topology automatically.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#9881;</div>
            <h3>APM &amp; Tracing</h3>
            <p>
              Distributed tracing across microservices. Track requests from
              browser to database. Identify bottlenecks and latency spikes
              instantly.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128202;</div>
            <h3>SLA &amp; Reporting</h3>
            <p>
              Automated SLA tracking with burn-rate alerts. Generate compliance
              reports for SOC 2, ISO 27001, and custom frameworks.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128272;</div>
            <h3>REST API &amp; CLI</h3>
            <p>
              Fully documented REST API with OpenAPI spec. CLI tool for
              scripting. Terraform provider for infrastructure-as-code
              monitoring.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--bg-secondary)">
      <div class="container">
        <div class="text-center" style="margin-bottom: var(--space-12)">
          <h2>Works with <span class="text-gradient">your stack</span></h2>
          <p class="subtitle subtitle-wide" style="margin-top: var(--space-4)">
            One lightweight agent covers everything. Auto-discovers services and
            starts collecting metrics in minutes.
          </p>
        </div>
        <div class="features-grid">
          <div class="feature-card">
            <h3>Cloud Providers</h3>
            <p>
              AWS, Google Cloud, Microsoft Azure, DigitalOcean, Hetzner,
              OVHcloud, Scaleway. Native APIs, no proxies needed.
            </p>
          </div>
          <div class="feature-card">
            <h3>Containers &amp; Orchestration</h3>
            <p>
              Docker, Kubernetes, ECS, Nomad, OpenShift. Auto-discover pods,
              track resource requests vs usage, alert on crashes.
            </p>
          </div>
          <div class="feature-card">
            <h3>Databases</h3>
            <p>
              PostgreSQL, MySQL, MongoDB, Redis, Elasticsearch, ClickHouse.
              Query performance, replication lag, connection pools.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <h2>
          Start monitoring <span class="text-gradient">in 5 minutes</span>
        </h2>
        <p class="subtitle subtitle-wide">
          Install the agent, see your metrics. No configuration needed.
        </p>
        <div class="hero-cta" style="margin-top: var(--space-8)">
          <a href="pricing.html" class="btn btn-primary btn-lg"
            >Start Free Trial &rarr;</a
          ><a href="contact.html" class="btn btn-secondary btn-lg"
            >Request a Demo</a
          >
        </div>
      </div>
    </section>
{% endblock %}
