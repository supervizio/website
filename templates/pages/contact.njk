{% set title = "Contact — Superviz.io" %}
{% set description = "Get in touch with the Superviz.io team. Sales inquiries, technical support, partnership requests, and general questions." %}
{% set canonical = "https://superviz.io/contact" %}
{% extends "layouts/base.njk" %}

{% block content %}
    <section class="page-header">
      <div class="container">
        <span class="badge">Contact</span>
        <h1 style="margin-top: var(--space-4)">
          Let's <span class="text-gradient">talk</span>
        </h1>
        <p class="subtitle subtitle-wide" style="margin-top: var(--space-4)">
          Whether you have questions about our platform, need a demo, or want to
          discuss enterprise deployment — we're here to help.
        </p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">&#128172;</div>
            <h3>Sales</h3>
            <p>
              Interested in Superviz.io for your team? Let's discuss your
              monitoring needs, deployment options, and pricing.
            </p>
            <p style="margin-top: var(--space-4); color: var(--text-muted)">
              Coming soon
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128736;</div>
            <h3>Technical Support</h3>
            <p>
              Already a customer? Our support team is ready to help with
              technical issues, configuration, and best practices.
            </p>
            <p style="margin-top: var(--space-4); color: var(--text-muted)">
              Coming soon
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#129309;</div>
            <h3>Partnerships</h3>
            <p>
              Interested in integrating with Superviz.io or becoming a reseller
              partner? Let's explore how we can work together.
            </p>
            <p style="margin-top: var(--space-4); color: var(--text-muted)">
              Coming soon
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--bg-secondary)">
      <div class="container">
        <div class="features-grid" style="grid-template-columns: 1fr 1fr">
          <div class="feature-card">
            <h3>Response Times</h3>
            <ul
              style="
                color: var(--text-secondary);
                line-height: 2.2;
                list-style: none;
                padding: 0;
              "
            >
              <li>
                <strong style="color: var(--text-primary)">Enterprise:</strong>
                15-minute SLA, 24/7
              </li>
              <li>
                <strong style="color: var(--text-primary)">Pro:</strong> 4-hour
                SLA, business hours
              </li>
              <li>
                <strong style="color: var(--text-primary)">Free:</strong>
                Community forum, best effort
              </li>
              <li>
                <strong style="color: var(--text-primary)">Sales:</strong>
                Within 1 business day
              </li>
            </ul>
          </div>
          <div class="feature-card">
            <h3>Office</h3>
            <p>
              <strong style="color: var(--text-primary)"
                >Superviz.io SAS</strong
              >
            </p>
            <p style="margin-top: var(--space-2)">
              42 Rue de la Bienfaisance<br />
              75008 Paris, France
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <h2>Ready to get <span class="text-gradient">started?</span></h2>
        <p class="subtitle subtitle-wide">
          Start monitoring for free, or request a personalized demo from our
          team.
        </p>
        <div class="hero-cta" style="margin-top: var(--space-8)">
          <a href="pricing.html" class="btn btn-primary btn-lg"
            >Start Free Trial &rarr;</a
          ><a href="enterprise.html" class="btn btn-secondary btn-lg"
            >Enterprise Solutions</a
          >
        </div>
      </div>
    </section>
{% endblock %}
