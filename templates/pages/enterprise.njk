{% set title = "Enterprise — Superviz.io" %}
{% set description = "Superviz.io Enterprise: dedicated infrastructure, SSO, RBAC, SLA guarantees, and 24/7 support for large-scale monitoring deployments." %}
{% set canonical = "https://superviz.io/enterprise" %}
{% extends "layouts/base.njk" %}

{% block content %}
    <section class="page-header">
      <div class="container">
        <span class="badge">Enterprise</span>
        <h1 style="margin-top: var(--space-4)">
          Monitoring built for<br /><span class="text-gradient"
            >scale and compliance</span
          >
        </h1>
        <p class="subtitle subtitle-wide" style="margin-top: var(--space-4)">
          Dedicated infrastructure, advanced security, and 24/7 support.
          Superviz.io Enterprise is trusted by Fortune 500 companies and
          fast-growing startups alike.
        </p>
        <div class="hero-cta" style="margin-top: var(--space-8)">
          <a href="contact.html" class="btn btn-primary btn-lg"
            >Talk to Sales &rarr;</a
          ><a href="pricing.html" class="btn btn-secondary btn-lg"
            >See Pricing</a
          >
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center" style="margin-bottom: var(--space-12)">
          <h2>Enterprise-grade <span class="text-gradient">security</span></h2>
          <p class="subtitle subtitle-wide" style="margin-top: var(--space-4)">
            Your data stays protected with industry-leading security controls
            and compliance certifications.
          </p>
        </div>
        <div class="security-grid">
          <div class="security-card">
            <div class="security-icon">&#128737;</div>
            <h3>SOC 2 Type II</h3>
            <p>
              Annual independent audits verify our security controls. Full
              report available under NDA for enterprise customers.
            </p>
          </div>
          <div class="security-card">
            <div class="security-icon">&#128274;</div>
            <h3>End-to-End Encryption</h3>
            <p>
              TLS 1.3 in transit, AES-256 at rest. Customer-managed encryption
              keys (CMEK) available for sensitive workloads.
            </p>
          </div>
          <div class="security-card">
            <div class="security-icon">&#127919;</div>
            <h3>GDPR &amp; HIPAA</h3>
            <p>
              Data residency in EU and US. Full GDPR compliance with DPA. HIPAA
              BAA available for healthcare customers.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="background: var(--bg-secondary)">
      <div class="container">
        <div class="text-center" style="margin-bottom: var(--space-12)">
          <h2>Built for <span class="text-gradient">large teams</span></h2>
        </div>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">&#128101;</div>
            <h3>SSO &amp; SAML</h3>
            <p>
              Single sign-on with Okta, Azure AD, Google Workspace, and any SAML
              2.0 or OIDC provider. Enforce MFA across your organization.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128274;</div>
            <h3>Role-Based Access</h3>
            <p>
              Granular RBAC with custom roles. Control who can view dashboards,
              edit alerts, manage integrations, or access billing.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128209;</div>
            <h3>Audit Logs</h3>
            <p>
              Complete audit trail of every action. Who changed what, when, and
              why. Export to your SIEM for centralized compliance.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#127758;</div>
            <h3>Multi-Region</h3>
            <p>
              Deploy across multiple regions for data sovereignty. Choose where
              your metrics are stored: EU, US, or Asia-Pacific.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128200;</div>
            <h3>Unlimited Dashboards</h3>
            <p>
              No limits on dashboards, alerts, or team members. Create
              department-specific views with fine-grained sharing controls.
            </p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#9881;</div>
            <h3>Dedicated Support</h3>
            <p>
              Named account manager, 24/7 priority support with a 15-minute
              response SLA, and quarterly business reviews.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="text-center" style="margin-bottom: var(--space-12)">
          <h2>Deployment <span class="text-gradient">options</span></h2>
          <p class="subtitle subtitle-wide" style="margin-top: var(--space-4)">
            Choose the deployment model that fits your security and compliance
            requirements.
          </p>
        </div>
        <div
          class="features-grid"
          style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr))"
        >
          <div class="feature-card">
            <div class="feature-icon">&#9729;</div>
            <h3>Superviz.io Cloud</h3>
            <p>
              Fully managed SaaS. We handle infrastructure, updates, and
              scaling. The fastest way to get started with zero operational
              overhead.
            </p>
            <ul
              style="
                margin-top: var(--space-4);
                color: var(--text-secondary);
                line-height: 2;
              "
            >
              <li>Automatic updates and patches</li>
              <li>99.9% uptime SLA</li>
              <li>Managed backups and disaster recovery</li>
            </ul>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#128187;</div>
            <h3>Dedicated Cloud</h3>
            <p>
              Single-tenant infrastructure in your preferred cloud region.
              Isolated compute and storage with full network controls.
            </p>
            <ul
              style="
                margin-top: var(--space-4);
                color: var(--text-secondary);
                line-height: 2;
              "
            >
              <li>Isolated single-tenant environment</li>
              <li>Custom network policies and VPC peering</li>
              <li>Dedicated encryption keys (CMEK)</li>
            </ul>
          </div>
          <div class="feature-card">
            <div class="feature-icon">&#127970;</div>
            <h3>On-Premise</h3>
            <p>
              Run Superviz.io inside your own data center. Full control over data
              and network. Air-gapped deployments supported.
            </p>
            <ul
              style="
                margin-top: var(--space-4);
                color: var(--text-secondary);
                line-height: 2;
              "
            >
              <li>Complete data sovereignty</li>
              <li>Air-gapped deployment option</li>
              <li>Kubernetes or bare-metal installation</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container">
        <h2>
          Ready to scale your
          <span class="text-gradient">monitoring?</span>
        </h2>
        <p class="subtitle subtitle-wide">
          Talk to our sales team about Enterprise pricing, deployment options,
          and a custom proof-of-concept.
        </p>
        <div class="hero-cta" style="margin-top: var(--space-8)">
          <a href="contact.html" class="btn btn-primary btn-lg"
            >Request a Demo &rarr;</a
          ><a href="pricing.html" class="btn btn-secondary btn-lg"
            >View Pricing</a
          >
        </div>
      </div>
    </section>
{% endblock %}
